# STT Inference Server - 환경변수 예시
# 복사 후 .env 로 저장하여 사용

# HuggingFace (pyannote 모델용, 필수)
HF_TOKEN=

# STT - Faster-Whisper
# STT_MODEL=large-v3
# STT_DEVICE=auto
# STT_COMPUTE_TYPE=float16
# STT_BEAM_SIZE=3
# STT_VAD_FILTER=true
# STT_VAD_MIN_SILENCE_MS=500
# STT_VAD_SPEECH_PAD_MS=200

# Diarization
# DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# Audio
# AUDIO_SAMPLE_RATE=16000
# AUDIO_CHANNELS=1
# FFMPEG_TIMEOUT=300

# API
# MAX_FILE_SIZE_MB=500
